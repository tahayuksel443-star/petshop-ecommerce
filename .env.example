# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/petshop_db"

# NextAuth
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars-here"
NEXTAUTH_URL="http://localhost:3000"

# Admin credentials
ADMIN_EMAIL="admin@petshop.com"
ADMIN_PASSWORD="admin123456"

# iyzico
IYZICO_API_KEY="sandbox-your-api-key"
IYZICO_SECRET_KEY="sandbox-your-secret-key"
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

# Site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Kosem Pet Shop"

# SMTP (iletisim formu icin)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="noreply@example.com"
